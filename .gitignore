# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# NOTE: This repo has Unity project in subfolder "Renaissance/"
# All paths below are relative to REPO root (RenaissanceREPO/)

Renaissance/.utmp/
Renaissance/[Ll]ibrary/
Renaissance/[Tt]emp/
Renaissance/[Oo]bj/
Renaissance/[Bb]uild/
Renaissance/[Bb]uilds/
Renaissance/[Ll]ogs/
Renaissance/[Uu]ser[Ss]ettings/
Renaissance/*.log

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
Renaissance/[Mm]emoryCaptures/

# Recordings can get excessive in size
Renaissance/[Rr]ecordings/

# Autogenerated Jetbrains Rider plugin
Renaissance/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/

# Gradle cache directory
Renaissance/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
Renaissance/ExportedObj/
Renaissance/.consulo/
Renaissance/*.csproj
Renaissance/*.unityproj
Renaissance/*.sln
Renaissance/*.suo
Renaissance/*.tmp
Renaissance/*.user
Renaissance/*.userprefs
Renaissance/*.pidb
Renaissance/*.booproj
Renaissance/*.svd
Renaissance/*.pdb
Renaissance/*.mdb
Renaissance/*.opendb
Renaissance/*.VC.db

# Unity3D generated meta files
Renaissance/*.pidb.meta
Renaissance/*.pdb.meta
Renaissance/*.mdb.meta

# Unity3D generated file on crash reports
Renaissance/sysinfo.txt

# Builds
Renaissance/*.apk
Renaissance/*.aab
Renaissance/*.unitypackage
Renaissance/*.unitypackage.meta
Renaissance/*.app

# Crashlytics generated file
Renaissance/crashlytics-build.properties

# Packed Addressables
Renaissance/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
Renaissance/[Aa]ssets/[Ss]treamingAssets/aa.meta
Renaissance/[Aa]ssets/[Ss]treamingAssets/aa/*

# Unity Package Manager
Renaissance/Packages/manifest.json.lock
Renaissance/Packages/packages-lock.json
